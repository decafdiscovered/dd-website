---
import '@styles/global.css';
import BaseHead from '@components/BaseHead.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import BuyMeACoffeeFab from '@components/BuyMeACoffeeFab.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
  canonical?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
}

const { title, description, image, type, publishedDate, canonical, structuredData, noindex } =
  Astro.props;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      publishedDate={publishedDate}
      canonical={canonical}
      structuredData={structuredData}
      noindex={noindex}
    />
  </head>
  <body class="flex min-h-screen flex-col">
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
    <BuyMeACoffeeFab />
    <!--
      Netlify Identity forwards password recovery / invite / email-confirmation
      links to whichever domain the email template points at (by default the
      .netlify.app subdomain). The Identity widget only loads on /admin, so if
      we detect one of those hash tokens outside /admin we forward there,
      preserving the hash. This is defensive — the CMS itself lives at /admin.
    -->
    <script is:inline>
      (function () {
        var hash = window.location.hash || '';
        if (!/^#(recovery_token|invite_token|confirmation_token|email_change_token|access_token)=/.test(hash)) return;
        if (window.location.pathname.replace(/\/+$/, '') === '/admin') return;
        window.location.replace('/admin/' + hash);
      })();
    </script>
  </body>
</html>
