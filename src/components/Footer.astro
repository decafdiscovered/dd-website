---
import { SITE } from '@utils/site';
import AffiliateDisclosure from './AffiliateDisclosure.astro';

const year = new Date().getFullYear();
---

<footer
  class="mt-24 border-t border-[color:var(--color-cream-200)] bg-[color:var(--color-cream-100)]"
>
  <div class="container-page grid gap-10 py-12 md:grid-cols-3">
    <div>
      <p class="font-display text-lg font-bold text-[color:var(--color-espresso)]">{SITE.name}</p>
      <p class="mt-2 max-w-xs text-sm text-[color:var(--color-mocha-700)]">{SITE.description}</p>
    </div>

    <nav aria-label="Footer" class="text-sm">
      <p class="mb-3 font-semibold text-[color:var(--color-espresso)]">Explore</p>
      <ul class="grid grid-cols-2 gap-y-2">
        <li><a href="/reviews">Reviews</a></li>
        <li><a href="/roasters">Roasters</a></li>
        <li><a href="/guides">Guides</a></li>
        <li><a href="/newsletter">Newsletter</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/rss.xml">RSS feed</a></li>
      </ul>
    </nav>

    <div class="text-sm">
      <p class="mb-3 font-semibold text-[color:var(--color-espresso)]">A note on links</p>
      <AffiliateDisclosure compact />
    </div>
  </div>

  <div class="border-t border-[color:var(--color-cream-200)]">
    <div
      class="container-page flex flex-col items-start justify-between gap-2 py-6 text-xs text-[color:var(--color-mocha-700)] md:flex-row md:items-center"
    >
      <p>&copy; {year} {SITE.name}. Written in the UK with plenty of decaf.</p>
      <p>Built with Astro, Tailwind and love.</p>
    </div>
  </div>
</footer>
