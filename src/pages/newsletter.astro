---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeading from '@components/SectionHeading.astro';
import NewsletterSignup from '@components/NewsletterSignup.astro';
---

<BaseLayout
  title="Newsletter"
  description="A short monthly round-up of every new decaf review, plus subscriber-only extras that don’t make it onto the site."
>
  <div class="container-page max-w-4xl py-16">
    <SectionHeading
      eyebrow="Once a month, into your inbox"
      title="The Decaf Discovered newsletter"
      description="A short monthly round-up of every new review, plus a bit you won't get from the site — what I'm brewing next, kit thoughts, and the odd honest disappointment."
      as="h1"
    />

    <NewsletterSignup
      variant="inline"
      heading="Sign up"
      subheading="No spam. Unsubscribe any time."
    />

    <section class="mt-16 grid gap-6 md:grid-cols-3">
      <div
        class="rounded-[var(--radius-card)] border border-[color:var(--color-cream-200)] bg-white p-6"
      >
        <p class="text-2xl">☕</p>
        <h3 class="mt-3 text-lg font-semibold">Real bags, real opinions</h3>
        <p class="mt-2 text-sm text-[color:var(--color-mocha-700)]">
          Only coffees I've actually paid for and brewed at home.
        </p>
      </div>
      <div
        class="rounded-[var(--radius-card)] border border-[color:var(--color-cream-200)] bg-white p-6"
      >
        <p class="text-2xl">🗞️</p>
        <h3 class="mt-3 text-lg font-semibold">A monthly round-up</h3>
        <p class="mt-2 text-sm text-[color:var(--color-mocha-700)]">
          One-line verdicts on every new review, with links to the full write-ups on the site.
        </p>
      </div>
      <div
        class="rounded-[var(--radius-card)] border border-[color:var(--color-cream-200)] bg-white p-6"
      >
        <p class="text-2xl">🤫</p>
        <h3 class="mt-3 text-lg font-semibold">Subscriber-only extras</h3>
        <p class="mt-2 text-sm text-[color:var(--color-mocha-700)]">
          Behind-the-scenes notes, what's brewing next, and the bits that don't make it onto the
          site.
        </p>
      </div>
    </section>

    <section class="mt-16">
      <h2 class="text-2xl font-bold">A peek at a recent issue</h2>
      <article
        class="mt-4 rounded-[var(--radius-card)] border border-[color:var(--color-cream-200)] bg-[color:var(--color-cream-100)] p-8"
      >
        <p class="text-xs tracking-wider text-[color:var(--color-mocha-500)] uppercase">
          Issue #12 · Sample
        </p>
        <h3 class="mt-2 text-xl font-semibold">Three new reviews and a bag I'm eyeing next</h3>
        <div class="prose-decaf mt-3 text-[color:var(--color-mocha-700)]">
          <p><strong>New on the site this month:</strong></p>
          <ul>
            <li>
              <strong>Guatemalan Hunbatz</strong> — chocolatey and forgiving, works well in milk. → <em
                >Read the full review</em
              >
            </li>
            <li>
              <strong>Brazilian Chocolate Decaf</strong> — the everyday espresso I keep coming back to.
              → <em>Read the full review</em>
            </li>
            <li>
              <strong>Colombian Swiss Water</strong> — a cleaner cup, best as filter. →
              <em>Read the full review</em>
            </li>
          </ul>
          <p>
            <strong>Not on the site:</strong> I've had my eye on a naturally-processed decaf from a small
            Yorkshire roaster for weeks. If it lives up to the hype, it'll be in next month's issue first.
          </p>
        </div>
        <p class="mt-4 text-sm text-[color:var(--color-mocha-500)]">
          Sample preview — the real newsletter will be sent by Beehiiv.
        </p>
      </article>
    </section>

    <section
      class="mt-16 rounded-[var(--radius-card)] bg-[color:var(--color-mocha-700)] p-10 text-center text-[color:var(--color-cream-50)]"
    >
      <h2 class="text-2xl font-bold">Ready when you are.</h2>
      <p class="mt-2">Scroll back up to sign up — takes about three seconds.</p>
      <a
        href="#top"
        class="mt-5 inline-block rounded-full bg-[color:var(--color-cream-50)] px-5 py-2 text-sm font-semibold text-[color:var(--color-espresso)] no-underline"
      >
        Back to signup
      </a>
    </section>
  </div>
</BaseLayout>
