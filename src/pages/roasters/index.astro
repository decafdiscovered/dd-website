---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeading from '@components/SectionHeading.astro';

const roasters = (await getCollection('roasters')).sort((a, b) =>
  a.data.name.localeCompare(b.data.name),
);
---

<BaseLayout
  title="Roasters"
  description="A directory of the UK-friendly decaf roasters featured on Decaf Discovered."
>
  <div class="container-page py-16">
    <SectionHeading
      eyebrow="Where the beans come from"
      title="Roasters"
      description="A small directory of the roasters whose decafs have made it into the Diaries."
      as="h1"
    />

    <ul class="grid gap-6 md:grid-cols-2">
      {
        roasters.map((roaster) => (
          <li class="rounded-[var(--radius-card)] border border-[color:var(--color-cream-200)] bg-white p-6 shadow-[var(--shadow-card)]">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h2 class="text-xl font-semibold">{roaster.data.name}</h2>
                <p class="text-sm text-[color:var(--color-mocha-500)]">{roaster.data.location}</p>
              </div>
              {roaster.data.isSampleContent && (
                <span class="rounded-full bg-[color:var(--color-cream-200)] px-2 py-0.5 text-[10px] font-medium tracking-wider text-[color:var(--color-mocha-700)] uppercase">
                  Sample
                </span>
              )}
            </div>
            <p class="mt-3 text-sm text-[color:var(--color-mocha-700)]">{roaster.data.summary}</p>
            {roaster.data.website && (
              <p class="mt-4 text-sm">
                <a href={roaster.data.website} rel="noopener" target="_blank">
                  Visit website →
                </a>
              </p>
            )}
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
