---
interface Props {
  label: string;
  emphasis?: boolean;
}
const { label, emphasis = false } = Astro.props;
---

<span
  class:list={[
    'inline-flex items-center gap-1 rounded-full border px-2.5 py-1 text-xs font-medium',
    emphasis
      ? 'bg-[color:var(--color-mocha-700)] text-[color:var(--color-cream-50)] border-transparent'
      : 'bg-[color:var(--color-cream-100)] text-[color:var(--color-mocha-700)] border-[color:var(--color-cream-200)]',
  ]}
>
  {label}
</span>
