---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeading from '@components/SectionHeading.astro';
import ReviewCard from '@components/ReviewCard.astro';
import NewsletterSignup from '@components/NewsletterSignup.astro';
import AffiliateDisclosure from '@components/AffiliateDisclosure.astro';
import { SITE, formatDate, isPublished } from '@utils/site';

const reviews = (
  await getCollection('reviews', ({ data }) => !data.draft && isPublished(data.publishedDate))
).sort((a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime());
const guides = (
  await getCollection('guides', ({ data }) => !data.draft && isPublished(data.publishedDate))
).sort((a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime());

const latestReviews = reviews.slice(0, 3);
const topRated = [...reviews]
  .sort((a, b) => b.data.ratings.overallScore - a.data.ratings.overallScore)
  .slice(0, 3);
const recentlyAdded = reviews.slice(0, 4);
const popularGuides = guides.slice(0, 3);
---

<BaseLayout title={SITE.name} description={SITE.description}>
  <!-- Hero -->
  <section
    class="relative overflow-hidden bg-gradient-to-b from-[color:var(--color-cream-100)] to-[color:var(--color-cream-50)]"
  >
    <div class="container-page max-w-4xl py-20 md:py-28">
      <p
        class="text-xs font-semibold tracking-[0.24em] text-[color:var(--color-mocha-500)] uppercase"
      >
        Decaf, done properly
      </p>
      <h1 class="mt-4 text-4xl leading-tight font-bold md:text-6xl">
        Finding great decaf coffee, <span class="text-[color:var(--color-mocha-700)]"
          >one bag at a time.</span
        >
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-[color:var(--color-mocha-700)] md:text-xl">
        Honest reviews of decaf beans from a normal coffee drinker. No coffee snobbery, just what
        tastes good.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/reviews" class="btn btn-primary no-underline">Browse reviews</a>
        <a href="/guides" class="btn btn-secondary no-underline">Read the guides</a>
      </div>
    </div>
  </section>

  <div class="container-page space-y-20 py-20">
    <!-- Latest reviews -->
    <section aria-labelledby="latest-reviews">
      <SectionHeading
        eyebrow="Fresh from the cupboard"
        title="Latest reviews"
        description="What I've been drinking recently."
        actionHref="/reviews"
        actionLabel="See all reviews"
      />
      {
        latestReviews.length === 0 ? (
          <p class="text-[color:var(--color-mocha-700)]">
            Reviews are on their way. Check back soon.
          </p>
        ) : (
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3" id="latest-reviews">
            {latestReviews.map((review) => (
              <ReviewCard review={review} />
            ))}
          </div>
        )
      }
    </section>

    <!-- Top rated -->
    <section
      aria-labelledby="top-rated"
      class="rounded-[var(--radius-card)] bg-[color:var(--color-cream-100)] p-8 md:p-12"
    >
      <SectionHeading
        eyebrow="The good stuff"
        title="Top rated decafs"
        description="If you want to skip straight to the winners, start here."
        actionHref="/reviews"
        actionLabel="See more"
      />
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3" id="top-rated">
        {topRated.map((review) => <ReviewCard review={review} />)}
      </div>
    </section>

    <!-- Recently added -->
    <section aria-labelledby="recently-added">
      <SectionHeading eyebrow="Just in" title="Recently added coffees" />
      <ul class="grid gap-3 md:grid-cols-2" id="recently-added">
        {
          recentlyAdded.map((review) => (
            <li class="flex items-center justify-between gap-4 rounded-lg border border-[color:var(--color-cream-200)] bg-white p-4">
              <div>
                <p class="text-xs text-[color:var(--color-mocha-500)]">
                  {formatDate(review.data.publishedDate)}
                </p>
                <a href={`/reviews/${review.id}/`} class="font-medium no-underline">
                  {review.data.coffeeName}
                </a>
                <p class="text-sm text-[color:var(--color-mocha-700)]">{review.data.roaster}</p>
              </div>
              <span class="rounded-full bg-[color:var(--color-mocha-700)] px-2.5 py-0.5 text-xs font-semibold text-[color:var(--color-cream-50)] tabular-nums">
                {review.data.ratings.overallScore.toFixed(1)}
              </span>
            </li>
          ))
        }
      </ul>
    </section>

    <!-- Popular guides -->
    <section aria-labelledby="popular-guides">
      <SectionHeading
        eyebrow="Learn as you sip"
        title="Popular guides"
        description="Beginner-friendly explainers, no jargon."
        actionHref="/guides"
        actionLabel="All guides"
      />
      <div class="grid gap-6 md:grid-cols-3">
        {
          popularGuides.map((guide) => (
            <a
              href={`/guides/${guide.id}/`}
              class="block rounded-[var(--radius-card)] border border-[color:var(--color-cream-200)] bg-white p-6 no-underline shadow-[var(--shadow-card)] transition-transform hover:-translate-y-0.5"
            >
              <p class="text-xs tracking-wider text-[color:var(--color-mocha-500)] uppercase">
                Guide
              </p>
              <h3 class="mt-2 text-xl font-semibold">{guide.data.title}</h3>
              <p class="mt-2 text-sm text-[color:var(--color-mocha-700)]">{guide.data.summary}</p>
              <p class="mt-4 text-sm font-medium text-[color:var(--color-mocha-700)]">
                Read guide →
              </p>
            </a>
          ))
        }
      </div>
    </section>

    <!-- Newsletter -->
    <NewsletterSignup />

    <!-- Affiliate disclosure -->
    <AffiliateDisclosure />
  </div>
</BaseLayout>
