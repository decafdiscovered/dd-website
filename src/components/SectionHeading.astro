---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  actionHref?: string;
  actionLabel?: string;
  as?: 'h1' | 'h2';
}

const { eyebrow, title, description, actionHref, actionLabel, as: Tag = 'h2' } = Astro.props;
---

<div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-8">
  <div>
    {eyebrow && (
      <p class="text-xs uppercase tracking-[0.18em] font-semibold text-[color:var(--color-mocha-500)] mb-2">{eyebrow}</p>
    )}
    <Tag class="text-3xl md:text-4xl font-bold">{title}</Tag>
    {description && <p class="mt-3 text-[color:var(--color-mocha-700)] max-w-2xl">{description}</p>}
  </div>
  {actionHref && actionLabel && (
    <a href={actionHref} class="btn btn-secondary self-start md:self-auto whitespace-nowrap no-underline">
      {actionLabel} <span aria-hidden="true">→</span>
    </a>
  )}
</div>
