---
interface Props {
  variant?: 'card' | 'inline';
  heading?: string;
  subheading?: string;
}

const {
  variant = 'card',
  heading = 'The Decaf Discovered newsletter',
  subheading = 'A monthly round-up of new decaf reviews — plus a couple of things you won’t find on the site: what I’m brewing next, quick notes, and the odd honest disappointment.',
} = Astro.props;

// Beehiiv form action gets swapped in via env; harmless placeholder in dev.
const action = import.meta.env.PUBLIC_BEEHIIV_FORM_ACTION ?? '#newsletter-not-configured';
const isConfigured = action !== '#newsletter-not-configured';
---

<section
  aria-label="Newsletter signup"
  class:list={[
    variant === 'card'
      ? 'rounded-[var(--radius-card)] border border-[color:var(--color-cream-200)] bg-[color:var(--color-cream-100)] p-8 shadow-[var(--shadow-card)]'
      : 'py-6',
  ]}
>
  <div class="max-w-2xl">
    <h2 class="text-2xl font-bold">{heading}</h2>
    <p class="mt-2 text-[color:var(--color-mocha-700)]">{subheading}</p>

    <form class="mt-6 flex flex-col gap-3 sm:flex-row" action={action} method="post" novalidate>
      <label class="flex-1">
        <span class="sr-only">Email address</span>
        <input
          type="email"
          name="email"
          required
          autocomplete="email"
          placeholder="you@example.com"
          class="w-full rounded-full border border-[color:var(--color-mocha-100)] bg-white px-4 py-3 text-sm"
        />
      </label>
      <button type="submit" class="btn btn-primary">Subscribe</button>
    </form>

    {
      !isConfigured && (
        <p class="mt-3 text-xs text-[color:var(--color-mocha-500)]">
          <strong>Demo mode:</strong> set{' '}
          <code class="rounded bg-[color:var(--color-cream-200)] px-1">
            PUBLIC_BEEHIIV_FORM_ACTION
          </code>{' '}
          to your Beehiiv embed URL to wire this up.
        </p>
      )
    }

    <p class="mt-2 text-xs text-[color:var(--color-mocha-700)]">
      By subscribing you agree to receive occasional emails. Unsubscribe any time.
    </p>
  </div>
</section>
