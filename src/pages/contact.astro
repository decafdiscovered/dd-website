---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeading from '@components/SectionHeading.astro';

const formspreeEndpoint = 'https://formspree.io/f/mjgngydn';
const turnstileSiteKey = '0x4AAAAAAD2p_ED2B-UUGZ-Q';
const submitted = Astro.url.searchParams.get('submitted') === 'true';
---

<BaseLayout
  title="Contact"
  description="Contact Decaf Discovered with questions, decaf coffee suggestions or partnership enquiries. I would love to hear from fellow coffee drinkers."
>
  <div class="container-page max-w-3xl py-16">
    <SectionHeading
      eyebrow="Say hello"
      title="Contact"
      description="Questions, coffee suggestions, or a roaster you think I should try next? Drop me a message below."
      as="h1"
    />

    {
      submitted && (
        <p
          class="mb-6 rounded-[var(--radius-card)] border border-[color:var(--color-leaf)] bg-white p-4 text-sm text-[color:var(--color-espresso)]"
          role="status"
          aria-live="polite"
        >
          Thanks, your message has been sent.
        </p>
      )
    }

    <form
      id="contact-form"
      class="rounded-[var(--radius-card)] border border-[color:var(--color-cream-200)] bg-white p-6 md:p-8"
      action={formspreeEndpoint}
      method="POST"
    >
      <input type="hidden" name="_subject" value="New contact form message from Decaf Discovered" />
      {/* _next is a no-JS fallback: Formspree redirects here after a native POST. */}
      <input type="hidden" name="_next" value="/contact?submitted=true#contact-form" />
      <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />

      <div class="grid gap-5">
        <label class="grid gap-1.5">
          <span class="text-sm font-semibold text-[color:var(--color-espresso)]">Name</span>
          <input
            type="text"
            name="name"
            required
            autocomplete="name"
            class="w-full rounded-lg border border-[color:var(--color-cream-200)] bg-[color:var(--color-cream-50)] px-3 py-2 text-[color:var(--color-espresso)]"
          />
        </label>

        <label class="grid gap-1.5">
          <span class="text-sm font-semibold text-[color:var(--color-espresso)]">Email</span>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            class="w-full rounded-lg border border-[color:var(--color-cream-200)] bg-[color:var(--color-cream-50)] px-3 py-2 text-[color:var(--color-espresso)]"
          />
        </label>

        <label class="grid gap-1.5">
          <span class="text-sm font-semibold text-[color:var(--color-espresso)]">Message</span>
          <textarea
            name="message"
            required
            rows="7"
            class="w-full rounded-lg border border-[color:var(--color-cream-200)] bg-[color:var(--color-cream-50)] px-3 py-2 text-[color:var(--color-espresso)]"
          ></textarea>
        </label>
      </div>

      <div class="mt-6">
        <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="light"></div>
      </div>

      <button id="contact-submit" type="submit" class="btn btn-primary mt-6">Send message</button>

      <p id="contact-status" role="status" aria-live="polite" class="mt-3 min-h-[1.25rem] text-sm">
      </p>

      <p class="mt-3 text-xs text-[color:var(--color-mocha-700)]">
        Protected by Cloudflare Turnstile. This site uses Formspree to process submissions.
      </p>
    </form>
  </div>

  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer
  ></script>

  <script is:inline define:vars={{ endpoint: formspreeEndpoint }}>
    // Submit the form via fetch with `Accept: application/json` so Formspree
    // responds with JSON instead of redirecting to its hosted thank-you page.
    // The native form action/_next remain as a fallback for users without JS.
    (function () {
      const form = document.getElementById('contact-form');
      const status = document.getElementById('contact-status');
      const submitBtn = document.getElementById('contact-submit');
      if (!form || !status || !submitBtn) return;

      const setStatus = (message, kind) => {
        status.textContent = message;
        status.className = 'mt-3 min-h-[1.25rem] text-sm';
        if (kind === 'ok') status.classList.add('text-[color:var(--color-leaf)]');
        if (kind === 'err') status.classList.add('text-red-700');
      };

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        setStatus('', null);

        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }

        const data = new FormData(form);
        const token = data.get('cf-turnstile-response');
        if (!token) {
          setStatus('Please complete the challenge before sending.', 'err');
          return;
        }

        submitBtn.disabled = true;
        const originalLabel = submitBtn.textContent;
        submitBtn.textContent = 'Sending…';

        try {
          const res = await fetch(endpoint, {
            method: 'POST',
            body: data,
            headers: { Accept: 'application/json' },
          });

          if (res.ok) {
            form.reset();
            if (window.turnstile) window.turnstile.reset();
            setStatus('Thanks, your message has been sent.', 'ok');
          } else {
            const body = await res.json().catch(() => null);
            const msg =
              (body && body.errors && body.errors[0] && body.errors[0].message) ||
              `Sorry, something went wrong (status ${res.status}). Please try again later.`;
            setStatus(msg, 'err');
          }
        } catch (_err) {
          setStatus('Network error. Please try again later.', 'err');
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = originalLabel;
        }
      });
    })();
  </script>
</BaseLayout>
