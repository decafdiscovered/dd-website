---
import { DECAF_METHODS, BEST_FOR_OPTIONS } from '../content/config';
import { FLAVOUR_TAGS } from '@utils/site';
---

<form
  id="review-filters"
  class="rounded-[var(--radius-card)] border border-[color:var(--color-cream-200)] bg-white p-5 shadow-[var(--shadow-card)]"
  aria-label="Filter reviews"
  data-filters
>
  <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
    <fieldset>
      <legend class="mb-2 text-sm font-semibold text-[color:var(--color-espresso)]">Decaf method</legend>
      <div class="flex flex-col gap-1.5">
        {
          DECAF_METHODS.map((method) => (
            <label class="inline-flex items-center gap-2 text-sm">
              <input type="checkbox" name="method" value={method} class="accent-[color:var(--color-mocha-700)]" />
              {method}
            </label>
          ))
        }
      </div>
    </fieldset>

    <fieldset>
      <legend class="mb-2 text-sm font-semibold text-[color:var(--color-espresso)]">Flavour</legend>
      <div class="flex flex-col gap-1.5">
        {
          FLAVOUR_TAGS.map((tag) => (
            <label class="inline-flex items-center gap-2 text-sm">
              <input type="checkbox" name="flavour" value={tag.toLowerCase()} class="accent-[color:var(--color-mocha-700)]" />
              {tag}
            </label>
          ))
        }
      </div>
    </fieldset>

    <fieldset>
      <legend class="mb-2 text-sm font-semibold text-[color:var(--color-espresso)]">Best for</legend>
      <div class="flex flex-col gap-1.5">
        {
          BEST_FOR_OPTIONS.map((use) => (
            <label class="inline-flex items-center gap-2 text-sm">
              <input type="checkbox" name="bestFor" value={use.toLowerCase()} class="accent-[color:var(--color-mocha-700)]" />
              {use}
            </label>
          ))
        }
      </div>
    </fieldset>

    <fieldset>
      <legend class="mb-2 text-sm font-semibold text-[color:var(--color-espresso)]">Minimum rating</legend>
      <label class="block text-sm">
        <span class="sr-only">Minimum rating</span>
        <input
          type="range"
          name="rating"
          min="1"
          max="10"
          step="0.5"
          value="1"
          class="w-full accent-[color:var(--color-mocha-700)]"
          data-rating-input
        />
        <span class="mt-1 block tabular-nums text-[color:var(--color-mocha-700)]">
          At least <span data-rating-output>1.0</span> / 10
        </span>
      </label>

      <label class="mt-4 block text-sm">
        <span class="font-semibold text-[color:var(--color-espresso)]">Search</span>
        <input
          type="search"
          name="q"
          placeholder="e.g. chocolate"
          class="mt-1 w-full rounded-md border border-[color:var(--color-cream-200)] bg-[color:var(--color-cream-50)] px-3 py-2 text-sm"
          data-text-input
        />
      </label>
    </fieldset>
  </div>

  <div class="mt-6 flex flex-wrap items-center justify-between gap-3">
    <p class="text-sm text-[color:var(--color-mocha-700)]">
      Showing <span data-visible-count>0</span> of <span data-total-count>0</span> coffees
    </p>
    <button type="reset" class="btn btn-secondary text-sm">Reset filters</button>
  </div>
</form>

<p
  class="mt-6 hidden rounded-md border border-dashed border-[color:var(--color-mocha-100)] bg-[color:var(--color-cream-50)] px-4 py-3 text-sm text-[color:var(--color-mocha-700)]"
  data-no-results
>
  No coffees match those filters yet. Try relaxing a filter or two.
</p>

<script>
  import { initReviewFilters } from '@scripts/reviewFilters';
  initReviewFilters();
</script>
