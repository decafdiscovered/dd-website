{
  "name": "Decaf Discovered (Node 20)",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-20-bookworm",

  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/azure-cli:1": {}
  },

  "forwardPorts": [4321],
  "portsAttributes": {
    "4321": {
      "label": "Astro dev server",
      "onAutoForward": "openBrowserOnce"
    }
  },

  "postCreateCommand": "sudo chown -R node:node node_modules && npm install",
  "postAttachCommand": {
    "welcome": "echo '☕ Decaf Discovered dev container ready. Run: npm run dev'"
  },

  "remoteUser": "node",
  "containerEnv": {
    "NODE_ENV": "development"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "astro-build.astro-vscode",
        "bradlc.vscode-tailwindcss",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "unifiedjs.vscode-mdx",
        "yzhang.markdown-all-in-one",
        "ms-azuretools.vscode-azurestaticwebapps",
        "github.vscode-github-actions",
        "eamodio.gitlens"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[astro]": { "editor.defaultFormatter": "astro-build.astro-vscode" },
        "[markdown]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
        "files.eol": "\n",
        "typescript.tsdk": "node_modules/typescript/lib",
        "tailwindCSS.includeLanguages": { "astro": "html" },
        "tailwindCSS.experimental.classRegex": [
          ["class:list=\\{([^}]*)\\}", "[\"'`]([^\"'`]*).*?[\"'`]"]
        ]
      }
    }
  },

  "mounts": [
    "source=decaf-discovered-node_modules,target=${containerWorkspaceFolder}/node_modules,type=volume"
  ]
}
