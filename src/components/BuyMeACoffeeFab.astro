---
import { SITE } from '@utils/site';

// A single floating "Buy me a coffee" button rendered site-wide.
// Fixed to the bottom-right corner and out of the document flow, so it
// stays visible while people scroll without pushing content around.
// Renders nothing if no URL is configured.
if (!SITE.buyMeACoffeeUrl) return null;
---

<a
  href={SITE.buyMeACoffeeUrl}
  rel="noopener"
  target="_blank"
  aria-label="Buy me a coffee (opens in a new tab)"
  class="group fixed right-4 bottom-4 z-50 inline-flex items-center gap-2 rounded-full bg-[color:var(--color-mocha-700)] px-4 py-3 text-sm font-semibold text-[color:var(--color-cream-50)] no-underline shadow-lg ring-1 ring-black/5 transition hover:-translate-y-0.5 hover:bg-[color:var(--color-espresso)] hover:shadow-xl focus-visible:ring-2 focus-visible:ring-[color:var(--color-espresso)] focus-visible:ring-offset-2 focus-visible:outline-none sm:right-6 sm:bottom-6"
  style="padding-bottom: max(0.75rem, env(safe-area-inset-bottom, 0.75rem)); padding-right: max(1rem, env(safe-area-inset-right, 1rem));"
>
  <span aria-hidden="true" class="text-lg leading-none">☕</span>
  <span class="hidden sm:inline">Buy me a coffee</span>
</a>
