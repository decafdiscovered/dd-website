---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeading from '@components/SectionHeading.astro';
import { formatDate } from '@utils/site';

const guides = (await getCollection('guides', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime(),
);
---

<BaseLayout
  title="Guides"
  description="Beginner-friendly guides to decaf coffee — methods, brewing, and what to look for."
>
  <div class="container-page py-16">
    <SectionHeading
      eyebrow="Learn as you sip"
      title="Guides"
      description="Approachable explainers, in plain English."
      as="h1"
    />

    <ul class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {guides.map((guide) => (
        <li>
          <a
            href={`/guides/${guide.id}/`}
            class="block h-full rounded-[var(--radius-card)] border border-[color:var(--color-cream-200)] bg-white p-6 no-underline shadow-[var(--shadow-card)] transition-transform hover:-translate-y-0.5"
          >
            <p class="text-xs uppercase tracking-wider text-[color:var(--color-mocha-500)]">
              {formatDate(guide.data.publishedDate)}
            </p>
            <h2 class="mt-2 text-xl font-semibold">{guide.data.title}</h2>
            <p class="mt-2 text-sm text-[color:var(--color-mocha-700)]">{guide.data.summary}</p>
            <p class="mt-4 text-sm font-medium text-[color:var(--color-mocha-700)]">Read guide →</p>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
